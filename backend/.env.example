# ============================================
# Median - AI Media Guardian
# Environment Configuration
# ============================================

# --- Google Cloud Credentials ---
# Path to your Google Cloud service account JSON key file.
# Create one at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Required APIs to enable:
#   1. Vertex AI API
#   2. Generative Language API (Gemini)
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account-key.json

# --- Google Cloud Project ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Gemini Model ---
# The Gemini model used for generating scan explanations.
GEMINI_MODEL=gemini-2.0-flash

# --- Application Settings ---
# Maximum upload file size in bytes (default: 10MB)
MAX_UPLOAD_SIZE=10485760
